# Philip (Bub 主入口) 配置
# 复制此文件为 .env 并填入实际值

# ---------------------------------------------------------------------------
# 必需配置
# ---------------------------------------------------------------------------
BUB_MODEL=anthropic:claude-sonnet-4-20250514
BUB_API_KEY=your-api-key-here
BUB_API_BASE=https://api.anthropic.com
BUB_WORKSPACE=/path/to/your-workspace

# ---------------------------------------------------------------------------
# 部署路径（docker compose 和 run-host.sh 共用）
# ---------------------------------------------------------------------------
# 容器时区（Docker 模式，默认 Asia/Shanghai）
# TZ=Asia/Shanghai

BUB_BOXSH=~/work/boxsh/philip
BUB_SKILLS=~/.agents/skills
BUB_WEIXIN_DATA=~/.openclaw/openclaw-weixin
BUB_FEISHU_HOME=~/.feishu
BUB_HOME=~/.bub

# 部署模式：
#   Docker 模式:  docker compose up    (使用 entrypoint.sh)
#   宿主机模式:   ./run-host.sh        (直接用 boxsh >= 2.1.0，不需要 Docker)
#
# 两种模式共用以上路径变量。当前语义：
#
#   BUB_WORKSPACE   - 真实工作区路径
#                     Docker 模式下作为 COW lower 层
#                     宿主机模式下直接以读写方式暴露给 agent
#   BUB_BOXSH       - Docker 模式 COW upper 层（映射为容器内 /workspace）
#   BUB_SKILLS      - skills 目录（沙箱内只读）
#   BUB_WEIXIN_DATA - 微信数据目录（沙箱内可写，可选，含登录凭据和同步状态）
#   BUB_FEISHU_HOME - feishu CLI 认证目录（沙箱内可写，可选，token 刷新需要）
#   BUB_HOME        - bub 主目录（默认 ~/.bub）
#
# 注意：app 代码通过 framework.workspace（来自 bub -w 参数）动态获取路径。
# Docker 模式 runtime workspace 是 /workspace；宿主机模式 runtime workspace 是 BUB_WORKSPACE 本身。

# ---------------------------------------------------------------------------
# Agent runtime（可选）
# ---------------------------------------------------------------------------
# BUB_MAX_STEPS=50
BUB_MAX_TOKENS=16384
# BUB_MODEL_TIMEOUT_SECONDS=300

# ---------------------------------------------------------------------------
# Channel manager（可选）
# ---------------------------------------------------------------------------
# Comma-separated channel names, or `all`
# BUB_ENABLED_CHANNELS=all
# BUB_DEBOUNCE_SECONDS=1.0
# BUB_MAX_WAIT_SECONDS=10.0
# BUB_ACTIVE_TIME_WINDOW=60.0

# ---------------------------------------------------------------------------
# WeChat（可选，默认无需配置）
# ---------------------------------------------------------------------------
# WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com
# WEIXIN_ACCOUNT_ID=your-account-id

# ---------------------------------------------------------------------------
# Telegram（可选）
# ---------------------------------------------------------------------------
# BUB_TELEGRAM_TOKEN=your-telegram-token
# BUB_TELEGRAM_ALLOW_USERS=user-id
# BUB_TELEGRAM_ALLOW_CHATS=chat-id
# BUB_TELEGRAM_PROXY=http://127.0.0.1:1087

# ---------------------------------------------------------------------------
# Feishu / 飞书（可选）
# ---------------------------------------------------------------------------
# 在飞书开放平台创建企业自建应用获取
# 文档：https://open.feishu.cn/document/server-side-sdk/python--sdk/preparations-before-development
#
# 必需配置
# BUB_FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
# BUB_FEISHU_APP_SECRET=your-app-secret
#
# Webhook 验证配置（可选，应用后台「事件与回调」页面配置）
# BUB_FEISHU_VERIFICATION_TOKEN=
# BUB_FEISHU_ENCRYPT_KEY=
#
# 允许的用户 open_id（可选，JSON 数组或逗号分隔，不设则不限制）
# BUB_FEISHU_ALLOW_USERS=ou_xxxxxxxxxxxxxxxx,ou_yyyyyyyyyyyyyyyy
#
# 允许的 Chat ID（可选，JSON 数组或逗号分隔，不设则不限制）
# BUB_FEISHU_ALLOW_CHATS=oc_xxxxxxxxxxxxxxxx,oc_yyyyyyyyyyyyyyyy
#
# 机器人 open_id（群聊 @机器人 功能必需）
# 注意：这不是 App ID，而是机器人的 open_id
#
# 获取方式一：启动服务后在群聊中 @机器人，查看日志输出的 mentions.id.open_id
#   日志示例：mention[0]: name=BotName open_id=ou_xxx ...
#
# 获取方式二：通过 API 获取
#   curl -X GET "https://open.feishu.cn/open-apis/bot/v3/info/" \
#     -H "Authorization: Bearer <tenant_access_token>"
#
# BUB_FEISHU_BOT_OPEN_ID=ou_xxxxxxxxxxxxxxxx
#
# 机器人显示名称（用于群聊中通过 @名称 匹配，大小写不敏感）
# 当未配置 BOT_OPEN_ID 或 open_id 匹配失败时，作为 fallback 匹配
# BUB_FEISHU_BOT_NAME=bub
#
# 消息队列配置（飞书 channel 优先级队列）
# BUB_FEISHU_QUEUE_MAX_LENGTH=100        # 队列最大长度，0=不限制（默认 0）
#                                        # 超出时丢弃普通消息，管理员消息不受限制
#
# 管理员配置（飞书 channel 最高优先级 + 可取消任务）
# 管理员消息绕过排队立即执行，可发送 ,cancel 取消所有排队和运行中的任务
# BUB_FEISHU_ADMIN_USERS=ou_xxxxxxxxxxxxxxxx  # 管理员 open_id，逗号分隔
